# Live OpenClaw API wiring
VITE_OPENCLAW_LIVE_ENABLED=true
VITE_OPENCLAW_BASE_URL=http://127.0.0.1:11434

# Auth mode: bearer | x-agent-token | x-api-key | both | auto
VITE_OPENCLAW_AUTH_MODE=bearer
VITE_OPENCLAW_BEARER_TOKEN=
VITE_OPENCLAW_AGENT_TOKEN=
VITE_OPENCLAW_API_KEY=

# IMPORTANT: default is strict - no silent fake success fallback.
VITE_OPENCLAW_ALLOW_LOCAL_FALLBACK=false

# Request timeout in milliseconds
VITE_OPENCLAW_REQUEST_TIMEOUT_MS=8000
