# ===== OpenClaw Mission Control runtime secrets (DO NOT COMMIT .env) =====

# Backend / gateway
OPENCLAW_BASE_URL=http://127.0.0.1:8000

# Auth contract for /api/v1/agent/*
# Choose one canonical mode and set matching credential(s).
OPENCLAW_AUTH_MODE=bearer
OPENCLAW_BEARER_TOKEN=
OPENCLAW_AGENT_TOKEN=
OPENCLAW_API_KEY=

# Optional timeout
OPENCLAW_REQUEST_TIMEOUT_MS=8000

# Stripe watcher
STRIPE_SECRET_KEY=

# ----- Frontend Vite mirrors (used by mission-control-new) -----
VITE_OPENCLAW_LIVE_ENABLED=true
VITE_OPENCLAW_BASE_URL=http://127.0.0.1:8000
VITE_OPENCLAW_AUTH_MODE=bearer
VITE_OPENCLAW_BEARER_TOKEN=
VITE_OPENCLAW_AGENT_TOKEN=
VITE_OPENCLAW_API_KEY=
VITE_OPENCLAW_ALLOW_LOCAL_FALLBACK=false
VITE_OPENCLAW_REQUEST_TIMEOUT_MS=8000
